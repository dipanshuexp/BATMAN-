<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>BATMAN</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@300;500;700&display=swap" rel="stylesheet">
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
html, body {
  background: #000;
  color: #e8e8e8;
  font-family: 'Rajdhani', sans-serif;
  overflow: hidden;
  height: 100%;
  width: 100%;
}
#hero {
  position: fixed;
  inset: 0;
  background: #000;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: opacity 0.8s ease, transform 0.8s ease;
}
#hero.hidden {
  opacity: 0;
  pointer-events: none;
  transform: scale(1.04);
}
.hero-bat {
  font-size: clamp(100px, 30vw, 180px);
  animation: batPulse 3s ease-in-out infinite;
  margin-bottom: 20px;
}
@keyframes batPulse {
  0%,100% { opacity: 0.9; transform: scale(1); filter: drop-shadow(0 0 30px #c9a84c66); }
  50% { opacity: 1; transform: scale(1.06); filter: drop-shadow(0 0 60px #c9a84caa); }
}
.hero-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(60px, 20vw, 130px);
  letter-spacing: 0.15em;
  color: #e8e8e8;
  text-shadow: 0 0 60px rgba(201,168,76,0.4);
  line-height: 1;
}
.hero-sub {
  font-size: clamp(10px, 3vw, 14px);
  letter-spacing: 0.5em;
  color: #c9a84c;
  text-transform: uppercase;
  margin-top: 12px;
}
.enter-btn {
  margin-top: 50px;
  padding: 14px 50px;
  border: 1px solid #c9a84c;
  background: transparent;
  color: #c9a84c;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 20px;
  letter-spacing: 0.3em;
  cursor: pointer;
  transition: background 0.3s, color 0.3s;
  -webkit-tap-highlight-color: transparent;
}
.enter-btn:active { background: #c9a84c; color: #000; }
.scanlines {
  position: fixed;
  inset: 0;
  background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.06) 2px, rgba(0,0,0,0.06) 4px);
  pointer-events: none;
  z-index: 9999;
}
#reel-wrap {
  position: fixed;
  inset: 0;
  overflow-y: scroll;
  scroll-snap-type: y mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.8s ease;
}
#reel-wrap.visible {
  opacity: 1;
  pointer-events: all;
}
#reel-wrap::-webkit-scrollbar { display: none; }
.reel {
  position: relative;
  width: 100vw;
  height: 100vh;
  scroll-snap-align: start;
  scroll-snap-stop: always;
  background: #000;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.reel video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.reel::after {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 40%),
    linear-gradient(to bottom, rgba(0,0,0,0.4) 0%, transparent 30%);
  pointer-events: none;
  z-index: 2;
}
.reel-topbar {
  position: absolute;
  top: 0; left: 0; right: 0;
  padding: 18px 20px 10px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 5;
}
.reel-logo {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 22px;
  letter-spacing: 0.2em;
  color: #c9a84c;
  text-shadow: 0 0 20px rgba(201,168,76,0.5);
}
.reel-counter {
  font-size: 12px;
  letter-spacing: 0.3em;
  color: rgba(255,255,255,0.5);
}
.reel-info {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 20px 20px 40px;
  z-index: 5;
}
.reel-num {
  font-size: 10px;
  letter-spacing: 0.4em;
  color: #c9a84c;
  margin-bottom: 4px;
  text-transform: uppercase;
}
.reel-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(26px, 7vw, 40px);
  letter-spacing: 0.08em;
  color: #fff;
  line-height: 1;
}
.scroll-hint {
  position: absolute;
  bottom: 16px;
  right: 20px;
  z-index: 5;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  opacity: 0.5;
}
.scroll-hint span {
  font-size: 9px;
  letter-spacing: 0.3em;
  color: #fff;
  text-transform: uppercase;
}
.scroll-hint-arrow {
  width: 1px;
  height: 30px;
  background: linear-gradient(180deg, rgba(255,255,255,0.8), transparent);
  animation: arrowPulse 1.5s ease-in-out infinite;
}
@keyframes arrowPulse {
  0%,100% { opacity: 0.5; transform: scaleY(1); }
  50% { opacity: 1; transform: scaleY(0.7) translateY(4px); }
}
.reel:last-child .scroll-hint { display: none; }
.tap-indicator {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%) scale(0);
  width: 70px; height: 70px;
  border: 2px solid rgba(255,255,255,0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 6;
  pointer-events: none;
  transition: transform 0.15s ease, opacity 0.3s ease;
  opacity: 0;
}
.tap-indicator svg { fill: #fff; width: 24px; height: 24px; margin-left: 4px; }
.tap-indicator.show { transform: translate(-50%, -50%) scale(1); opacity: 1; }
.tap-indicator.hide { transform: translate(-50%, -50%) scale(1.3); opacity: 0; }
.mute-btn {
  position: fixed;
  top: 18px;
  right: 14px;
  z-index: 200;
  background: rgba(0,0,0,0.5);
  border: 1px solid rgba(201,168,76,0.4);
  color: #c9a84c;
  font-size: 18px;
  width: 38px; height: 38px;
  border-radius: 50%;
  display: none;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
}
.mute-btn.visible { display: flex; }
.progress-dots {
  position: fixed;
  right: 6px;
  top: 50%;
  transform: translateY(-50%);
  display: none;
  flex-direction: column;
  gap: 8px;
  z-index: 200;
}
.progress-dots.visible { display: flex; }
.dot {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  transition: background 0.3s, height 0.3s;
}
.dot.active {
  background: #c9a84c;
  height: 16px;
  border-radius: 2px;
}
</style>
</head>
<body>

<div class="scanlines"></div>

<div id="hero">
  <div class="hero-bat">🦇</div>
  <div class="hero-title">BATMAN</div>
  <div class="hero-sub">I Am The Night</div>
  <button class="enter-btn" onclick="enterReels()">ENTER GOTHAM</button>
  <a href="https://instagram.com/dipanshu.exp" target="_blank" class="creator-tag">
  created by : @dipanshu.exp
</a>
</div>

<button class="mute-btn" id="muteBtn" onclick="toggleMute()">🔇</button>

<div class="progress-dots" id="dots">
  <div class="dot active"></div>
  <div class="dot"></div>
  <div class="dot"></div>
  <div class="dot"></div>
</div>

<div id="reel-wrap">

  <div class="reel" id="reel0">
    <video id="vid0" loop playsinline preload="auto" src="https://res.cloudinary.com/dl0haulhb/video/upload/v1775308555/_323469419_3_erac7m.mp4"></video>
    <div class="reel-topbar">
      <div class="reel-logo">🦇 BATMAN</div>
      <div class="reel-counter">01 / 04</div>
    </div>
    <div class="reel-info">
      <div class="reel-num">File 001</div>
      <div class="reel-title">Rise of the Dark Knight</div>
    </div>
    <div class="tap-indicator" id="tap0"><svg viewBox="0 0 24 24"><polygon points="5,3 19,12 5,21"/></svg></div>
    <div class="scroll-hint"><div class="scroll-hint-arrow"></div><span>Scroll</span></div>
  </div>

  <div class="reel" id="reel1">
    <video id="vid1" loop playsinline preload="auto" src="https://res.cloudinary.com/dl0haulhb/video/upload/v1775308546/_324491008_t4hqn1.mp4"></video>
    <div class="reel-topbar">
      <div class="reel-logo">🦇 BATMAN</div>
      <div class="reel-counter">02 / 04</div>
    </div>
    <div class="reel-info">
      <div class="reel-num">File 002</div>
      <div class="reel-title">Shadows of Gotham</div>
    </div>
    <div class="tap-indicator" id="tap1"><svg viewBox="0 0 24 24"><polygon points="5,3 19,12 5,21"/></svg></div>
    <div class="scroll-hint"><div class="scroll-hint-arrow"></div><span>Scroll</span></div>
  </div>

  <div class="reel" id="reel2">
    <video id="vid2" loop playsinline preload="auto" src="https://res.cloudinary.com/dl0haulhb/video/upload/v1775308519/_324414031_eq5ivv.mp4"></video>
    <div class="reel-topbar">
      <div class="reel-logo">🦇 BATMAN</div>
      <div class="reel-counter">03 / 04</div>
    </div>
    <div class="reel-info">
      <div class="reel-num">File 003</div>
      <div class="reel-title">Vengeance Awakened</div>
    </div>
    <div class="tap-indicator" id="tap2"><svg viewBox="0 0 24 24"><polygon points="5,3 19,12 5,21"/></svg></div>
    <div class="scroll-hint"><div class="scroll-hint-arrow"></div><span>Scroll</span></div>
  </div>

  <div class="reel" id="reel3">
    <video id="vid3" loop playsinline preload="auto" src="https://res.cloudinary.com/dl0haulhb/video/upload/v1775308545/_324115963_gvexu1.mp4"></video>
    <div class="reel-topbar">
      <div class="reel-logo">🦇 BATMAN</div>
      <div class="reel-counter">04 / 04</div>
    </div>
    <div class="reel-info">
      <div class="reel-num">File 004</div>
      <div class="reel-title">The Night Never Ends</div>
    </div>
    <div class="tap-indicator" id="tap3"><svg viewBox="0 0 24 24"><polygon points="5,3 19,12 5,21"/></svg></div>
  </div>

</div>

<script>
var videos = [
  document.getElementById('vid0'),
  document.getElementById('vid1'),
  document.getElementById('vid2'),
  document.getElementById('vid3')
];
var reels = [
  document.getElementById('reel0'),
  document.getElementById('reel1'),
  document.getElementById('reel2'),
  document.getElementById('reel3')
];
var taps = [
  document.getElementById('tap0'),
  document.getElementById('tap1'),
  document.getElementById('tap2'),
  document.getElementById('tap3')
];
var dots = document.querySelectorAll('.dot');
var wrap = document.getElementById('reel-wrap');
var muteBtn = document.getElementById('muteBtn');
var currentIndex = 0;
var isMuted = false;
var tapTimeout = null;
var scrollTimer = null;

videos.forEach(function(v) { v.muted = true; });

function enterReels() {
  document.getElementById('hero').classList.add('hidden');
  wrap.classList.add('visible');
  document.getElementById('dots').classList.add('visible');
  muteBtn.classList.add('visible');
  isMuted = false;
  videos.forEach(function(v) { v.muted = false; });
  muteBtn.textContent = '🔊';
  playVideo(0);
}

function playVideo(i) {
  videos.forEach(function(v, j) {
    if (j !== i) { v.pause(); v.currentTime = 0; }
  });
  videos[i].muted = isMuted;
  videos[i].play().catch(function() {
    videos[i].muted = true;
    videos[i].play();
    muteBtn.textContent = '🔇';
  });
}

function updateDots(i) {
  dots.forEach(function(d, j) {
    if (j === i) { d.classList.add('active'); }
    else { d.classList.remove('active'); }
  });
}

wrap.addEventListener('scroll', function() {
  clearTimeout(scrollTimer);
  scrollTimer = setTimeout(function() {
    var idx = Math.round(wrap.scrollTop / window.innerHeight);
    if (idx !== currentIndex) {
      currentIndex = idx;
      playVideo(currentIndex);
      updateDots(currentIndex);
    }
  }, 80);
});

reels.forEach(function(reel, i) {
  reel.addEventListener('click', function() {
    var vid = videos[i];
    var tap = taps[i];
    clearTimeout(tapTimeout);
    if (vid.paused) {
      vid.play();
      tap.innerHTML = '<svg viewBox="0 0 24 24"><polygon points="5,3 19,12 5,21" fill="white"/></svg>';
    } else {
      vid.pause();
      tap.innerHTML = '<svg viewBox="0 0 24 24"><rect x="5" y="3" width="4" height="18" fill="white"/><rect x="15" y="3" width="4" height="18" fill="white"/></svg>';
    }
    tap.classList.remove('hide');
    tap.classList.add('show');
    tapTimeout = setTimeout(function() {
      tap.classList.remove('show');
      tap.classList.add('hide');
      setTimeout(function() { tap.classList.remove('hide'); }, 300);
    }, 600);
  });
});

function toggleMute() {
  isMuted = !isMuted;
  videos.forEach(function(v) { v.muted = isMuted; });
  muteBtn.textContent = isMuted ? '🔇' : '🔊';
  if (!isMuted) { videos[currentIndex].muted = false; }
}

document.addEventListener('keydown', function(e) {
  if (e.key === 'ArrowDown' && currentIndex < 3) {
    currentIndex++;
    wrap.scrollTo({ top: currentIndex * window.innerHeight, behavior: 'smooth' });
    playVideo(currentIndex);
    updateDots(currentIndex);
  }
  if (e.key === 'ArrowUp' && currentIndex > 0) {
    currentIndex--;
    wrap.scrollTo({ top: currentIndex * window.innerHeight, behavior: 'smooth' });
    playVideo(currentIndex);
    updateDots(currentIndex);
  }
});
</script>

</body>
</html>